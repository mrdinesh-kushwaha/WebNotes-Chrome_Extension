{
  "manifest_version": 3,
  "name": "WebNotes – Capture & Save Website Notes",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "description": "Save selected text and paragraphs from any website as persistent notes with search, tags, and export support.",
  "permissions": [
    "storage",
    "contextMenus",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
  "default_title": "WebNotes",
  "default_icon": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png"
  }
},
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open WebNotes side panel"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
